{
  "crons": [
    { "path": "/api/cron/monitor", "schedule": "0 0 * * *" }
  ],
  "rewrites": [
    { "source": "/auth/:path*", "destination": "/api" },
    { "source": "/api/github/:path*", "destination": "/api" },
    { "source": "/api/health", "destination": "/api" },
    { "source": "/api/monitor/:path*", "destination": "/api" }
  ]
}
